{
  "manifest_version": 3,
  "name": "StormDecode",
  "version": "1.0",
  "description": "Makes Hebrew text easier to read for users with dyslexia.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
